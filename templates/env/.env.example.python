# Python Environment Variables
# This file documents required environment variable names for Python projects.
# Do not commit real secret values. Use .env.local or .env.development for actual values.

# Application environment
APP_ENV=development
LOG_LEVEL=debug

# Release/build metadata
GIT_SHA=
APP_VERSION=

# Honeybadger error reporting
# Do not commit real API keys.
HONEYBADGER_API_KEY=
HONEYBADGER_ENVIRONMENT=development

# Optional: Database connection
# DATABASE_URL=

# Optional: API keys
# API_KEY=
# SECRET_KEY=