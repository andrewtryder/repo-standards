# Cloudflare Worker Environment Variables
# This file documents required environment variable names for Cloudflare Workers.
# Do not commit real secret values. Use Wrangler secrets or Cloudflare secrets for production.

# Application environment
APP_ENV=development
LOG_LEVEL=debug

# Release/build metadata
GIT_SHA=
APP_VERSION=

# Honeybadger error reporting
# Do not commit real API keys.
# Production secrets should be configured with Wrangler secrets:
#   wrangler secret put HONEYBADGER_API_KEY
#   wrangler secret put HONEYBADGER_ENVIRONMENT
HONEYBADGER_API_KEY=
HONEYBADGER_ENVIRONMENT=development

# Optional: Database connection
# DATABASE_URL=

# Optional: API keys
# API_KEY=
# SECRET_KEY=

# Note: For production, use wrangler secret put <SECRET_NAME> to set secrets
# These will not be committed to git and are only available at runtime.